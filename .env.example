# AI Pulse — required secrets.
# Copy this file to `.env` for local runs (the .env is git-ignored), or set
# these as GitHub Actions secrets for scheduled runs. Never commit real values.

# --- Anthropic (Claude) ---
# Create at https://console.anthropic.com/ -> Settings -> API Keys.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Microsoft Teams (Power Automate "Workflows" incoming webhooks) ---
# Two SEPARATE webhooks. See README "Creating the Teams webhooks".
# Phase A draft is posted here, for Policy & Strategy review:
TEAMS_REVIEW_WEBHOOK_URL=https://prod-XX.westeurope.logic.azure.com:443/workflows/.../triggers/manual/paths/invoke?...
# Phase B broadcast is posted here, to the all-staff channel, ONLY on approval:
TEAMS_BROADCAST_WEBHOOK_URL=https://prod-YY.westeurope.logic.azure.com:443/workflows/.../triggers/manual/paths/invoke?...
